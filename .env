# CLIProxyAPI / Gemini
CLIPROXY_BASE_URL=http://127.0.0.1:8317
CLIPROXY_API_KEY=
CLIPROXY_TIMEOUT_SECONDS=30
GEMINI_BOSS_MODEL=gemini-3.1-pro-preview
GEMINI_AGENTS_MODEL=gemini-3-flash-preview
GEMINI_REFLECTION_MODEL=gemini-3-flash-preview

# Exa
EXA_API_KEYS=fad98c8c-e808-4dbe-97f9-bca7da4dd905
EXA_TIMEOUT_SECONDS=20
EXA_DAILY_BUDGET_PER_AGENT=20

# Screener CLI
SCREENER_BINARY_PATH=../screener/screener
SCREENER_SCREEN_URLS=
SCREENER_TIMEOUT_SECONDS=30
SCREENER_RETRIES=2

# Database and capital
DATABASE_URL=sqlite:///data/quant_trading.db
INITIAL_CAPITAL=1000000

# Web control room
WEB_HOST=127.0.0.1
WEB_PORT=8800
WEB_PASSWORD=quant
WEB_SESSION_SECRET=change-me
WEB_WEBSOCKET_REFRESH_SECONDS=5
WEB_FRONTEND_DIR=frontend
WEB_STATIC_DIR=frontend/dist

# Notes
# - The application reads environment variables directly. It does not auto-load .env.
# - Use ops/scripts/run-service.sh or export these variables in your shell / service manager.
# - SCREENER_SCREEN_URLS expects a comma-separated list of Screener screen URLs.
# - EXA_API_KEYS expects a comma-separated list of API keys.
