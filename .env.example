# CLIProxyAPI / Gemini
# On Linux VPS: runs locally after one-time headless login (see ops/scripts/setup-cliproxy-linux.sh)
CLIPROXY_BASE_URL=http://127.0.0.1:8317
# Use the key printed by CLIProxy during setup
CLIPROXY_API_KEY=quant-control-room-local
CLIPROXY_TIMEOUT_SECONDS=30
GEMINI_BOSS_MODEL=gemini-3.1-pro-preview
GEMINI_AGENTS_MODEL=gemini-3-flash-preview
GEMINI_REFLECTION_MODEL=gemini-3-flash-preview

# Exa
EXA_API_KEYS=
EXA_TIMEOUT_SECONDS=20
EXA_DAILY_BUDGET_PER_AGENT=20

# Screener CLI
# On Linux VPS: absolute path to Linux ELF screener binary (see ops/scripts/setup-linux.sh)
# Leave empty if no Linux binary available (quality/universe agents degrade gracefully)
SCREENER_BINARY_PATH=
SCREENER_TIMEOUT_SECONDS=30
SCREENER_RETRIES=2

# Database and capital
DATABASE_URL=sqlite:///data/quant_trading.db
INITIAL_CAPITAL=1000000

# Web control room
# On Linux VPS: set to 0.0.0.0 to allow external access (put behind nginx/caddy for HTTPS)
WEB_HOST=0.0.0.0
WEB_PORT=8800
WEB_LOG_LEVEL=warning
WEB_PASSWORD=quant
WEB_SESSION_SECRET=change-me
WEB_WEBSOCKET_REFRESH_SECONDS=5
WEB_FRONTEND_DIR=frontend
WEB_STATIC_DIR=frontend/dist

# Notes
# - The application reads environment variables directly. It does not auto-load .env.
# - Use ops/scripts/run-service.sh or export these variables in your shell / service manager.
# - EXA_API_KEYS expects a comma-separated list of API keys.
# - On Linux VPS: run ops/scripts/setup-linux.sh once to install the screener binary.
# - On Linux VPS: run ops/scripts/setup-cliproxy-linux.sh once to authenticate Gemini headlessly.
